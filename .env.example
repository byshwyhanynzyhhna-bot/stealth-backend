# ================================================
# STEALTH CALCULATOR - Environment Variables
# ================================================
# IMPORTANT: Copy this file to .env and fill in real values
# NEVER commit .env to version control!

# ================================================
# NEON.TECH POSTGRESQL
# Get this from your Neon.tech dashboard
# Format: postgresql://user:password@host.neon.tech/dbname?sslmode=require
# ================================================
NEON_DATABASE_URL=postgresql://user:password@your-project.neon.tech/dbname?sslmode=require

# Connection pool settings (Neon handles this automatically)
# For serverless, keep max connections low
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=10000

# ================================================
# FIREBASE CLOUD MESSAGING
# Get from Firebase Console > Project Settings > Cloud Messaging
# ================================================
FCM_SERVER_KEY=your_firebase_server_key_here
FCM_PROJECT_ID=your_firebase_project_id

# ================================================
# SERVER CONFIG
# ================================================
PORT=3000
NODE_ENV=development

# ================================================
# SECURITY
# ================================================
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Socket.io
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000